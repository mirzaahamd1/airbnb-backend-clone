<%-include('../partials/head.ejs')%>
  </head>
  <body>
    <%-include('../partials/nav.ejs')%>
    <main>
      <h2>Available Homes</h2>
      <ul class="homes-list">

        <% registeredHomes.forEach((home)=>{ %>
          <li class="home-card">

            <img src="<%= home.photoUrl %>" alt="home image" class="home-img">

            <div class="home-info">
              <h3 class="home-title"><%= home.houseName %></h3>
              <p class="home-location">📍 <%= home.location %></p>
              <p class="home-rating">⭐ <%= home.rating %> / 5</p>
              <p class="home-price">$<%= home.price %> / night</p><br>
              <p class="home-price"><%= home.description %> t</p>

              <!-- Action Buttons -->
              <div class="home-actions" style="margin-top: 10px;">
                <a href="edit-home/<%= home.id %>?editing=true" class="btn btn-edit" style="margin-right: 5px; padding: 5px 10px; background-color: #4CAF50; color: white; text-decoration: none; border-radius: 5px;">Edit</a>
                <form action="/delete-home/<%= home.id %>" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-delete" style="padding: 5px 10px; background-color: #f44336; color: white; border: none; border-radius: 5px; cursor: pointer;">Delete</button>
                </form>
              </div>

            </div>

          </li>
        <% }) %>

      </ul>
    </main>
  </body>
</html>