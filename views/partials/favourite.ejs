<form action="/favourites" method="POST">
    <input type="hidden" name="homeId" value="<%=home.id%>">

    <button type="submit"
        style="
        background:#ffa238;
        color:white;
        border:none;
        padding:10px 18px;
        font-size:15px;
        font-weight:600;
        border-radius:8px;
        cursor:pointer;
        margin-top:12px;
        box-shadow:0 4px 10px rgba(0,0,0,0.1);
        transition:0.2s;
        ">
        ❤️ Add to Favorites
    </button>
</form>